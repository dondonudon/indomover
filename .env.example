# =============================================================================
# Indo Mover — environment variables
# =============================================================================
# Copy this file to `.env` for local development. Each section explains where
# the variable is used and which "scope" it belongs to in Vercel.
#
# Three scopes:
#   • LOCAL ONLY   — only in your `.env` file when running `npm run build` here
#   • VERCEL BUILD — paste into Vercel → Project Settings → Environment
#                    Variables, with "Production" + "Preview" checked
#   • VERCEL CRON  — paste into Vercel env vars, "Production" only
# =============================================================================


# -----------------------------------------------------------------------------
# Section 1 — Google Places review fetcher
# Used by:  scripts/fetch-reviews.mjs   (runs as `prebuild`)
# Scope:    LOCAL ONLY + VERCEL BUILD
# Notes:    Both must be set together. The key is server-side only and never
#           reaches the browser bundle. Restrict the key in GCP to the
#           "Places API (New)" only.
# -----------------------------------------------------------------------------

# Already filled in — leave this value as-is. It is the Google Place ID
# that uniquely identifies the Indo Mover Semarang listing. (The string
# below looks random because Place IDs are opaque tokens, not names.)
GOOGLE_PLACE_ID=ChIJ9U5j8FPzcC4RGfoJsjexJvY

# REQUIRED — paste your Google Places API (New) key here when you copy
# this file to `.env`. Looks like: AIzaSy...  (39 chars total)
# Do NOT commit the real key — `.env` is gitignored on purpose.
GOOGLE_PLACES_KEY=


# -----------------------------------------------------------------------------
# Section 2 — Daily cron refresh
# Used by:  api/cron-rebuild.ts   (Vercel Edge function, fired by Vercel Cron)
# Scope:    VERCEL CRON only — never set locally, never commit
# -----------------------------------------------------------------------------

# REQUIRED in Vercel — Deploy Hook URL.
# Create it in Vercel → Project Settings → Git → Deploy Hooks
#   Name:   Daily reviews refresh
#   Branch: main
# Copy the generated URL (it looks like https://api.vercel.com/v1/integrations/deploy/...)
VERCEL_DEPLOY_HOOK_URL=

# DO NOT SET MANUALLY — Vercel auto-injects CRON_SECRET on every cron invocation.
# It's listed here only for documentation; the cron handler reads it at runtime.
# CRON_SECRET=<auto-set by Vercel>
